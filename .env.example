# Example environment variables required for production
# Copy this to .env.local or configure on your deployment platform

# GROQ API key for Groq SDK (server-side only)
GROQ_API_KEY=your-groq-api-key

# Membrain service credentials (server-side)
MEMBRAIN_API_KEY=your-membrain-api-key
MEMBRAIN_BASE_URL=https://api.your-membrain-service.example

# Default project id used by APIs when one is not supplied
DEFAULT_PROJECT_ID=default
